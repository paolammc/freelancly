generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  client
  freelancer
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskSource {
  ai
  manual
}

enum ProjectStatus {
  active
  completed
  paused
}

enum Priority {
  low
  medium
  high
  urgent
}

enum EstimateStatus {
  draft
  sent
  approved
  rejected
  expired
}

enum PaymentStatus {
  pending
  paid
  overdue
  refunded
  cancelled
}

// ========================================
// CLIENT MARKETPLACE & PIPELINE ENUMS
// ========================================

enum ListingStatus {
  open
  in_progress
  closed
  filled
}

enum ListingCategory {
  design
  development
  writing
  marketing
  video
  data
  consulting
  other
}

enum ListingDuration {
  short_term    // < 1 month
  medium_term   // 1-3 months
  long_term     // 3+ months
}

enum PipelineStage {
  prospecting
  contacted
  proposal_sent
  negotiating
  won
  lost
}

enum AvailabilityStatus {
  available
  limited
  unavailable
}

enum ExperienceLevel {
  entry
  mid
  senior
  expert
}

model User {
  id          String   @id @default(uuid())
  clerkUserId String   @unique
  email       String
  role        Role?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  freelancerProfile  FreelancerProfile?
  clientProjects     Project[]       @relation("ClientProjects")
  freelancerProjects Project[]       @relation("FreelancerProjects")
  assignedTasks      Task[]
  timeEntries        TimeEntry[]
  comments           Comment[]
  estimates          Estimate[]      @relation("FreelancerEstimates")
  clientEstimates    Estimate[]      @relation("ClientEstimates")
  payments           Payment[]
  clientListings     ClientListing[]
}

model FreelancerProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName        String
  title           String
  bio             String
  skills          String[]
  hourlyRate      Decimal            @db.Decimal(10, 2)
  portfolioUrl    String?
  avatarUrl       String?
  availability    AvailabilityStatus @default(available)
  experienceLevel ExperienceLevel    @default(mid)
  projectsCount   Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  reviews Review[]
}

model Project {
  id           String        @id @default(uuid())
  clientId     String
  client       User          @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User          @relation("FreelancerProjects", fields: [freelancerId], references: [id], onDelete: Cascade)
  title        String
  description  String
  budget       Decimal?      @db.Decimal(10, 2)
  deadline     DateTime?
  meetingUrl   String?
  status       ProjectStatus @default(active)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tasks     Task[]
  estimates Estimate[]
  roadmaps  Roadmap[]
  prds      PRD[]
}

model Task {
  id               String     @id @default(uuid())
  projectId        String
  project          Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  status           TaskStatus @default(todo)
  assigneeUserId   String?
  assignee         User?      @relation(fields: [assigneeUserId], references: [id], onDelete: SetNull)
  source           TaskSource @default(manual)
  priority         Priority   @default(medium)
  tags             String[]
  estimatedSeconds Int?
  dueDate          DateTime?
  parentTaskId     String?
  parentTask       Task?      @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks         Task[]     @relation("TaskSubtasks")
  order            Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  timeEntries TimeEntry[]
  comments    Comment[]
}

model TimeEntry {
  id              String    @id @default(uuid())
  taskId          String
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime       DateTime
  endTime         DateTime?
  durationSeconds Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Estimate {
  id           String         @id @default(uuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User           @relation("FreelancerEstimates", fields: [freelancerId], references: [id], onDelete: Cascade)
  clientId     String
  client       User           @relation("ClientEstimates", fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       EstimateStatus @default(draft)
  validUntil   DateTime?
  approvalToken String?       @unique
  sentAt       DateTime?
  approvedAt   DateTime?
  totalAmount  Decimal        @db.Decimal(10, 2)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  items    EstimateItem[]
  payments Payment[]
}

model EstimateItem {
  id          String   @id @default(uuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(10, 2)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id         String        @id @default(uuid())
  estimateId String
  estimate   Estimate      @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Decimal       @db.Decimal(10, 2)
  status     PaymentStatus @default(pending)
  method     String?
  paidAt     DateTime?
  dueDate    DateTime?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  receipt Receipt?
}

model Receipt {
  id          String   @id @default(uuid())
  paymentId   String   @unique
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  receiptNumber String @unique
  issuedAt    DateTime @default(now())
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Roadmap {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  phases      Json     // Array of phases with milestones, timelines
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PRD {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  problem     String?
  goals       String?
  features    Json?    // Array of feature objects
  userFlows   Json?    // Array of user flow objects
  metrics     Json?    // Success metrics
  content     String?  // Full markdown content
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========================================
// CLIENT MARKETPLACE - Project Listings
// ========================================

model ClientListing {
  id             String           @id @default(uuid())
  clientId       String
  client         User             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title          String
  description    String
  category       ListingCategory
  budgetMin      Decimal?         @db.Decimal(10, 2)
  budgetMax      Decimal?         @db.Decimal(10, 2)
  duration       ListingDuration  @default(medium_term)
  requiredSkills String[]
  timeline       String?          // e.g., "2-4 weeks"
  status         ListingStatus    @default(open)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  pipelineCards PipelineCard[]
}

// ========================================
// PIPELINE - Opportunity Tracking
// ========================================

model PipelineCard {
  id            String        @id @default(uuid())
  freelancerId  String
  listingId     String?
  listing       ClientListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  stage         PipelineStage @default(prospecting)
  title         String        // Cached from listing or custom
  clientName    String        // Cached client name
  budget        Decimal?      @db.Decimal(10, 2)
  notes         String?
  nextAction    String?
  stageEnteredAt DateTime     @default(now())
  listingClosed Boolean       @default(false)
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ========================================
// REVIEWS - Freelancer Ratings
// ========================================

model Review {
  id                  String            @id @default(uuid())
  freelancerProfileId String
  freelancerProfile   FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  clientId            String
  projectId           String?
  rating              Int               // 1-5
  comment             String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}
